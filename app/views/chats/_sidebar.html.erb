<div style="padding: 15px 15px 0px 15px; width: 30%; margin-right: 30px; background-color: #fbfbfb;">
    <div class="justify-between items-center mt-10 mr-10">
      <h1 class="font-bold text-4xl">Rag Assitant</h1>
      <h2 class="text-m">AI interview / study</h2>
      <div style="margin-top: 20px" class="items-center gap-2">
        <%= link_to new_chat_path, style: "width: 80%", class: "wd-2 text-center rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" do %>
          + Nova conversa
        <% end %>
      </div>
    </div>

    <div id="chats" class="divide-y divide-gray-200 space-y-5">
      <div style="font-weight: 700; margin-top: 50px">Conversas</div>
      <% if @chats.any? %>
        <% @chats.each do |chat| %>
          <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
            <%= link_to chat do %>
              <%= render chat %>
            <% end %>
            <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
              <%= button_to "Destroy", chat, method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-red-600 hover:bg-red-500 text-white inline-block font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-center my-10">No chats found.</p>
      <% end %>
    </div>
  </div>
