<% content_for :title, "Showing chat" %>

<%= turbo_stream_from "chat_#{@chat.id}" %>

<div class="md:w-2/3 w-full mb-2">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex">
    <%= render "sidebar" %>

    <div class="w-full divide-y divide-gray-200 space-y-5">
      <h1 style="padding: 25px 0px 30px 0;" class="font-bold text-4xl">
        <%= @chat.messages.second.content %>
      </h1>

      <div id="messages" class="min-w-full divide-y divide-gray-200 space-y-5 my-5">
        <% @chat_messages.each do |message| %>
          <%= render message %>
        <% end %>
      </div>

      <%= render "messages/form", chat: @chat, message: @message %>
    </div>
  </div>
</div>
